# --- Database (PlanetScale Postgres) ---
# Use the POOLED connection string from PlanetScale for serverless (Vercel).
# It's standard Postgres, so transactions + row locks (SELECT ... FOR UPDATE) work.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- App ---
# Public base URL, used for Stripe redirect URLs and pass/verify links.
APP_BASE_URL=http://localhost:3000

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From `stripe listen` locally, or the Dashboard webhook endpoint in prod.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Admin / staff access (simple shared secrets for v1) ---
# The admin dashboard and the staff scanner are gated by these.
# Replace before going live.
ADMIN_TOKEN=change-me-admin
STAFF_TOKEN=change-me-staff
